{
 "version": 2,
 "installCommand": "npm install --legacy-peer-deps",
 "builds": [
 {
 "src": "backend/server.js",
 "use": "@vercel/node"
 },
 {
 "src": "frontend/package.json",
 "use": "@vercel/static-build",
 "config": { "distDir": "build" }
 }
 ],
 "routes": [
 {
 "src": "/api/(.*)",
 "dest": "server/server.js"
 },
 {
 "src": "/(.*)",
 "dest": "client/build/$1"
 }
 ]
}